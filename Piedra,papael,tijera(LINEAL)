#include <iostream>
using namespace std;

int main() {
	int j1, j2;
	
	cout << "Jugador 1 ingrese su jugada:\n";
	cout << "1 = Piedra\n";
	cout << "2 = Papel\n";
	cout << "3 = Tijera\n";
	cin >> j1;
	
	cout << "\nJugador 2 ingrese su jugada:\n";
	cout << "1 = Piedra\n";
	cout << "2 = Papel\n";
	cout << "3 = Tijera\n";
	cin >> j2;
	
	cout << "\nJugador 1 eligio: ";
	if (j1 == 1)
		cout << "Piedra";
	else if (j1 == 2)
		cout << "Papel";
	else if (j1 == 3)
		cout << "Tijera";
	else
		cout << "Opcion invalida";
	
	cout << "\nJugador 2 eligio: ";
	if (j2 == 1)
		cout << "Piedra";
	else if (j2 == 2)
		cout << "Papel";
	else if (j2 == 3)
		cout << "Tijera";
	else
		cout << "Opcion invalida";
	
	cout << "\n\nResultado: ";
	
	if (j1 == j2)
		cout << "Empate";
	else if ((j1 == 1 && j2 == 3) ||
		(j1 == 2 && j2 == 1) ||
		(j1 == 3 && j2 == 2))
		cout << "Gana Jugador 1";
	else if ((j2 == 1 && j1 == 3) ||
		(j2 == 2 && j1 == 1) ||
		(j2 == 3 && j1 == 2))
		cout << "Gana Jugador 2";
	else
		cout << "No se puede determinar (jugada invalida)";
	
	return 0;
}
